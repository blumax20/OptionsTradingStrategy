+# === Execution & Microstructure Helpers (Almgren & Chriss; Cont & Kukanov) ===
+@dataclass
+class ExecutionParams:
+    use_limit: bool = True            # toggle limit vs market execution
+    base_spread_bps: float = 5.0      # baseline half-spread in bps of price
+    vol_slippage_k: float = 0.15      # scales with intraday volatility
+    size_impact_k: float = 0.0001     # simple square-root impact proxy
+
+def est_half_spread(price, atr, vol_slippage_k, base_spread_bps):
+    """
+    Estimate the half-spread as a function of price and volatility.
+    Cont (2011): microstructure noise grows with volatility.
+    """
+    return price * (base_spread_bps/1e4) + vol_slippage_k * (atr / max(1e-9, price))
+
+def exec_price(side, px_mid, half_spread, size, size_impact_k, use_limit):
+    """
+    Compute an execution-adjusted price. Market orders cross the spread and
+    incur a simple square-root impact; limit orders assume a mid-price fill
+    (20% spread capture).
+    """
+    if not use_limit:
+        cross = half_spread
+        impact = size_impact_k * (abs(size) ** 0.5) * px_mid
+        return px_mid + (cross + impact) * (1 if side > 0 else -1)
+    else:
+        return px_mid + (0.20 * half_spread) * (1 if side > 0 else -1)
+
 
